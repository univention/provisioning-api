#!/bin/bash

set -ex

coverage combine --data-file=/app/combined --keep /coverage/*

cd /app/.venv/lib/python3.11/site-packages
coverage report --rcfile=/app/udm-transformer/pyproject.toml --data-file=/app/combined --show-missing > /app/combined.txt
coverage xml --rcfile=/app/udm-transformer/pyproject.toml --data-file=/app/combined -o /app/combined.xml

/usr/local/bin/fix_e2e_coverage_xml /app/combined.xml /app/combined_fixed.xml
