[nats/user]
Description[en]=Nats user name specific to UdmProducerSettings
Description[de]=NATS-Benutzername, der für UdmProducerSettings spezifisch is
Type=str

[nats/password]
Description[en]=Nats password specific to UdmProducerSettings
Description[de]=NATS-Passwort, das für UdmProducerSettings spezifisch ist
Type=str

[nats/host]
Description[en]=Nats host name or IP address
Description[de]=NATS-Host-Name oder IP-Adresse
Type=str

[nats/port]
Description[en]=Nats port number
Description[de]=NATS-Portnummer
Type=portnumber
Default=4222

[nats/max_reconnect_attempts]
Description[en]=Maximum number of reconnect attempts to the NATS server
Description[de]=Maximale Anzahl von Wiederverbindungsversuchen zum NATS-Server
Type=str
Default=10
